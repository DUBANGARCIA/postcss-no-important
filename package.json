{
  "name": "postcss-no-important",
  "version": "11.0.0",
  "description": "PostCSS plugin for delete declarations !important",
  "keywords": [
    "postcss",
    "css",
    "postcss-plugin",
    "important"
  ],
  "homepage": "https://github.com/DUBANGARCIA/postcss-no-important",
  "bugs": {
    "url": "https://github.com/DUBANGARCIA/postcss-no-important/issues"
  },
  "repository": "DUBANGARCIA/postcss-no-important",
  "license": "MIT",
  "author": "Duban Garcia <duban162008@gmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build:release": "rm -rf ./dist ./dist-releas && bun --bun tsup",
    "commit": "bun --bun git-czg",
    "postinstall": "bun --bun sort-package-json",
    "prepare": "bun --bun is-ci || (echo 'You are not in CI, installing hooks...' && lefthook install)",
    "release": "env $(cat .env | xargs) bun release-it --ci",
    "test": "bun vitest run",
    "test:coverage": "bun vitest run --coverage",
    "test:watch": "bun vitest",
    "type-check": "bun --bun tsc --noEmit"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git",
      "czConfig": "./commitlint.config.js",
      "useEmoji": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@release-it/bumper": "7.0.6",
    "@release-it/conventional-changelog": "10.0.6",
    "@taplo/cli": "0.7.0",
    "@tsconfig/bun": "1.0.10",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/node-ts": "23.6.4",
    "@tsconfig/recommended": "1.0.13",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.2",
    "@vitest/coverage-v8": "4.1.8",
    "clean-publish": "7.1.0",
    "cz-git": "1.13.1",
    "czg": "1.13.1",
    "is-ci": "4.1.0",
    "release-it": "20.2.0",
    "sort-package-json": "3.7.1",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "postcss": "^8.4.0"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "directory": "dist"
  },
  "clean-publish": {
    "withoutPublish": true,
    "tempDir": "dist",
    "files": [
      ".idea"
    ]
  }
}
